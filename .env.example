# Copy this file to ".env.local" and fill in the value, then restart `npm run dev`.

# URL of the deployed Google Apps Script Web App that serves the student
# directory as JSON. It ends in /exec. See google-apps-script/README.md for how
# to deploy the script and obtain this URL.
#
# Leave blank to show built-in sample profiles instead of live data.
VITE_STUDENTS_ENDPOINT=https://script.google.com
